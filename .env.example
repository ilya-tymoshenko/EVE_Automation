# Copy this file to .env and fill secret values locally.

EVE_ACCOUNT_USERNAME_PREFIX=my.eve.online.
EVE_ACCOUNT_PASSWORD=
EVE_START_ACCOUNT=31
EVE_END_ACCOUNT=2000

EVE_LAUNCHER_COMMAND=
EVE_LAUNCHER_EXECUTABLE_PATH=
EVE_STEAM_APP_ID=8500
EVE_IMAGE_ONLY_UI=1
EVE_IMAGE_MATCH_DIAGNOSTICS=0
EVE_TIMEOUT_LAUNCHER_READY=120
EVE_TIMEOUT_LOGIN_DIALOG_READY=60
EVE_TIMEOUT_AFTER_SIGN_IN_READY=120
EVE_TIMEOUT_GAME_LAUNCH_VERIFICATION=120
EVE_TIMEOUT_EMAIL_VERIFICATION_PAGE=20
EVE_TIMEOUT_EMAIL_VERIFICATION_CODE=120
EVE_EMAIL_VERIFICATION_POLL_SECONDS=5
EVE_EMAIL_VERIFICATION_REQUEST_SKEW_SECONDS=5
EVE_TIMEOUT_GAME_READY_FOR_INPUT=180
EVE_TIMEOUT_GAME_POPUP_SCAN=2
EVE_TIMEOUT_GAME_POPUP_QUICK_SCAN=1
EVE_TIMEOUT_GAME_REQUIRED_ACTION=15
EVE_TIMEOUT_GAME_REQUIRED_STATE=20
EVE_TIMEOUT_GAME_OPTIONAL_ACTION=4
EVE_TIMEOUT_GAME_UI_AFTER_3D_TOGGLE=8
EVE_TIMEOUT_GAME_QUIT_MENU_READY=25
EVE_TIMEOUT_GAME_EXIT_TO_LAUNCHER=120
EVE_TIMEOUT_LAUNCHER_RECOVERY=90
EVE_TIMEOUT_LAUNCHER_FOCUS_VERIFY=4
EVE_TIMEOUT_LAUNCHER_ACCOUNT_REMOVAL_READY=3
EVE_TIMEOUT_LAUNCHER_AFTER_F11=20
EVE_TIMEOUT_OPTIONAL_CONFIRM_DIALOG=4
EVE_MAX_GAME_POPUP_CLOSE_ATTEMPTS=4
EVE_MAX_GAME_QUIT_MENU_ATTEMPTS=4
EVE_MAX_GAME_CONTRACT_VIEW_ATTEMPTS=3
EVE_MAX_GAME_LEFT_MENU_OPEN_ATTEMPTS=4
EVE_GAME_READY_STABLE_SECONDS=3
EVE_LAUNCHER_READY_STABLE_SECONDS=3
EVE_LAUNCHER_FULLSCREEN_ON_START=1
EVE_LAUNCHER_FULLSCREEN_MIN_MEAN_DIFF=4.0
EVE_DISABLE_3D_RENDERING_ON_GAME_START=0
EVE_DISABLE_3D_RENDERING_ATTEMPTS=2
EVE_DISABLE_3D_RENDERING_MIN_MEAN_DIFF=4.0
EVE_REQUIRE_3D_RENDERING_TOGGLE_CONFIRMATION=1
EVE_PAUSE_AFTER_DISABLE_3D_RENDERING=1.5
EVE_LAUNCHER_ACTION_RETRIES=3
EVE_LAUNCHER_START_COMMAND_ATTEMPTS=2
EVE_LAUNCHER_FOCUS_ATTEMPTS=3
EVE_LAUNCHER_WINDOW_TITLE_PATTERNS=eve launcher,eve online
EVE_LAUNCHER_WINDOW_APP_ID_PATTERNS=evelauncher,eve,steam
EVE_LAUNCHER_WINDOW_IGNORE_PATTERNS=tray
EVE_GAME_PROCESS_PATTERNS=exefile.exe

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PROJECT_ID=
GOOGLE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_AUTH_PROVIDER_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
GOOGLE_REDIRECT_URIS=http://localhost

GMAIL_REFRESH_TOKEN=
GMAIL_ACCESS_TOKEN=
GMAIL_TOKEN_PATH=token.json
GMAIL_ALLOW_INTERACTIVE_AUTH=0
GMAIL_EVE_VERIFICATION_QUERIES=newer_than:1d (from:eveonline.com OR from:ccpgames.com)||newer_than:1d ("verification code" OR "verification" OR "login code" OR "complete login")
GMAIL_EVE_VERIFICATION_CODE_REGEX=(?<!\d)(\d{6})(?!\d)

OPENAI_API_KEY=
OPENAI_REPAIR_MODEL=gpt-5.5
OPENAI_REPAIR_MAX_CYCLES=1
OPENAI_REPAIR_TIMEOUT_SECONDS=120
OPENAI_REPAIR_MAX_OUTPUT_TOKENS=2000
OPENAI_REPAIR_SOURCE_FILES=eve_bot.py,eve_config.py,mail.py,preflight.py,requirements.txt
OPENAI_REPAIR_MAX_SOURCE_CHARS_PER_FILE=35000
OPENAI_REPAIR_MAX_LOG_TAIL_CHARS=20000
