# Copy this file to .env and fill secret values locally.

EVE_ACCOUNT_USERNAME_PREFIX=my.eve.online.
EVE_ACCOUNT_PASSWORD=
EVE_START_ACCOUNT=1
EVE_END_ACCOUNT=2000

EVE_LAUNCHER_COMMAND=
EVE_LAUNCHER_EXECUTABLE_PATH=
EVE_STEAM_APP_ID=8500

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PROJECT_ID=
GOOGLE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_AUTH_PROVIDER_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
GOOGLE_REDIRECT_URIS=http://localhost

GMAIL_REFRESH_TOKEN=
GMAIL_ACCESS_TOKEN=
GMAIL_TOKEN_PATH=

OPENAI_API_KEY=
OPENAI_REPAIR_MODEL=gpt-5.5
OPENAI_REPAIR_MAX_CYCLES=1
OPENAI_REPAIR_TIMEOUT_SECONDS=120
OPENAI_REPAIR_MAX_OUTPUT_TOKENS=2000
OPENAI_REPAIR_SOURCE_FILES=eve_bot.py,eve_config.py,mail.py,preflight.py,requirements.txt
OPENAI_REPAIR_MAX_SOURCE_CHARS_PER_FILE=35000
OPENAI_REPAIR_MAX_LOG_TAIL_CHARS=20000
